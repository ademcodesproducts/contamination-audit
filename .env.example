# Copy this file to .env and fill in your keys. .env is gitignored.

# OpenAI: used by the LLM judge (stage 3) and the answer-equivalence judge (stage 8).
OPENAI_API_KEY=sk-...

# Anthropic: optional, used by `scripts/08_score_answers.py --provider anthropic`
# for Claude Haiku 4.5-based answer equivalence checks.
ANTHROPIC_API_KEY=sk-ant-...

# Google: optional, used for Gemini 2.5 Flash-based judging (paper used this for Tulu).
GOOGLE_API_KEY=...

# Hugging Face: needed to download Tulu 3 mixture; some HF auth-gated datasets.
HF_TOKEN=hf_...
